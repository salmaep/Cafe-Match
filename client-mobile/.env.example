# Salin file ini ke .env dan isi sesuai environment masing-masing.
# Catatan: env yang dipakai client harus diawali EXPO_PUBLIC_ agar bisa diakses dari app.config.ts.

# Base URL backend API (NestJS). Untuk dev di emulator/device, gunakan IP local network.
EXPO_PUBLIC_API_URL=http://192.168.1.21:3084/api/v1

# Google Maps API Key & Map ID (digunakan saat build agar Maps berjalan di production)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ─── Native social auth (mobile-only) ─────────────────────────────────────
# Mobile uses expo-auth-session to talk to Google/Facebook DIRECTLY, no
# server-side OAuth proxy. Tokens are POSTed to:
#   POST /auth/google/idtoken
#   POST /auth/facebook/token
#
# GOOGLE — Get OAuth 2.0 client IDs from https://console.cloud.google.com/
# (APIs & Services → Credentials). For Expo Go you only need the Web client.
# For native dev/prod builds, also create iOS + Android clients.
#   Web client: same project as your server's GOOGLE_CLIENT_ID
#   iOS client: bundle id = ios.bundleIdentifier from app.config.ts
#   Android client: package = android.package, SHA-1 from EAS / keystore
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=

# FACEBOOK — From https://developers.facebook.com/apps/ (your app's settings).
# This is the App ID (public). The App Secret stays on the server only.
EXPO_PUBLIC_FB_APP_ID=
