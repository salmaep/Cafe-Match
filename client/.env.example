
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_INFEED_SLOT=
# Copy to .env on each environment (dev, staging, prod).
# Vite reads this automatically during `vite build` and bakes values into the JS bundle.
# Note: ALL VITE_* values are PUBLIC — they end up in the bundle. Don't put secrets here.

VITE_API_URL=https://api.salma.imola.ai/api/v1

# Google Maps JavaScript API key (browser-exposed, restrict by HTTP referrer in GCP)
VITE_GOOGLE_MAPS_API_KEY=
# Optional: Cloud-based map style ID. Leave blank to use Google default style.
VITE_GOOGLE_MAPS_MAP_ID=
