DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=cafematch
JWT_SECRET=cafematch-jwt-secret-change-in-production
JWT_EXPIRATION=7d
GOOGLE_PLACES_API_KEY=
PORT=3000
MIDTRANS_SERVER_KEY=SB-Mid-server-wPBp95t6881tmXJPd5fGckbY
MIDTRANS_CLIENT_KEY=SB-Mid-client-hssQin2PdCq8AtL9
MIDTRANS_IS_PRODUCTION=false

# DEV TOGGLE: bypass 100m GPS check on check-in. Remove or set to false for production.
CHECKIN_SKIP_GPS=true

# Scraper sync API key — must match x-api-key header sent by scraper bot
SCRAPER_API_KEY=cafematch-scraper-key-change-in-production

# ─── Meilisearch ─────────────────────────────────────────────────────────────
# When NestJS runs on HOST (dev): http://localhost:7700
# When NestJS runs in Docker container: http://meilisearch:7700 (overridden by docker-compose)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=cafematch-meili-master-key-change-in-production
MEILI_CAFES_INDEX=cafes
MEILI_TIMEOUT_MS=5000
MEILI_SEMANTIC_RATIO=0.5

# Sync behavior
MEILI_SYNC_ENABLED=true
MEILI_WRITE_FAIL_OPEN=true

# ─── Jina Embeddings ─────────────────────────────────────────────────────────
# Get free API key at https://jina.ai (1M tokens/month free)
JINA_API_KEY=
JINA_MODEL=jina-embeddings-v3
JINA_DIMENSIONS=1024
