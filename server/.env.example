# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=cafematch
DB_PASSWORD=cafematch_pass
DB_DATABASE=cafematch

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRATION=7d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3084
NODE_ENV=production

# Public web origin used to build absolute URLs in /sitemap.xml and /robots.txt.
# No trailing slash.
PUBLIC_WEB_URL=https://salma.imola.ai

# ─── Payments (Midtrans) ──────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ─── Google ───────────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Dev Toggles ──────────────────────────────────────────────────────────────
CHECKIN_SKIP_GPS=false

# ─── Scraper ──────────────────────────────────────────────────────────────────
SCRAPER_API_KEY=change-this-to-a-strong-random-key

# ─── Meilisearch ─────────────────────────────────────────────────────────────
# When NestJS runs on HOST (dev): http://localhost:7700
# When NestJS runs in Docker container: http://meilisearch:7700 (overridden by docker-compose.yml)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=change-this-to-a-strong-random-key
MEILI_CAFES_INDEX=cafes
MEILI_TIMEOUT_MS=5000
# DEPRECATED — search uses full-text only. Hybrid path was removed from the
# search service. These vars stay defined to avoid breaking older .env files.
MEILI_SEMANTIC_RATIO=0
MEILI_HYBRID_ENABLED=false

# Sync behavior
# MEILI_SYNC_ENABLED=false  → disable all Meili sync (emergency MySQL-only mode)
MEILI_SYNC_ENABLED=true
# MEILI_WRITE_FAIL_OPEN=true → MySQL writes succeed even when Meili is unreachable (sync queued for retry)
MEILI_WRITE_FAIL_OPEN=true

# ─── Jina Embeddings ─────────────────────────────────────────────────────────
# Required for hybrid (semantic) search. Get free API key at https://jina.ai
JINA_API_KEY=
JINA_MODEL=jina-embeddings-v3
JINA_DIMENSIONS=1024
